package templates

templ layout(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<title>{ title }</title>
			<script src="https://unpkg.com/htmx.org@1.9.12"></script>
			<link rel="stylesheet" href="/static/style.css"/>
		</head>
		<body>
			<nav class="topnav">
				<a href="/problems">CodeEval</a>
				<a href="/logout">Log out</a>
			</nav>
			<main>
				{ children... }
			</main>
		</body>
	</html>
}
